# --- Database (Vercel Postgres) ---
# En Vercel: Storage -> Create Database -> Postgres, y copiá la connection string
# pooled (para runtime). Para migraciones podés usar la misma.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# --- Auth.js ---
# Genera con: npx auth secret   (o: openssl rand -base64 33)
AUTH_SECRET=""

# Login simple usuario/contraseña (sin registro, sin OAuth). Elegí lo que quieras.
APP_USERNAME=""
APP_PASSWORD=""

# --- Web Push (VAPID) ---
# Genera con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
