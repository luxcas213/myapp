// Prisma schema — personal PWA (notes, tracker, push notifications)
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Accounts are created by the owner (script), not via public signup.
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String   @default("")
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Generic personal tracker entry. `kind` groups entries (e.g. "mood", "workout", "expense")
// and `data` holds kind-specific fields as JSON so new trackers don't need schema changes.
model TrackerEntry {
  id         String   @id @default(cuid())
  kind       String
  value      Float?
  note       String?
  data       Json?
  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([kind])
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

// SIMPLE: notification only, no history/progress at all. COMPOUND: has
// history/progress (streak, heatmap), confirmed via `confirmMode`.
enum TrackingType {
  SIMPLE
  COMPOUND
}

// Only meaningful when trackingType = COMPOUND. SLIDER: plain confirm, no
// fields. FORM: renders `Task.formSchema` dynamically (see below).
enum ConfirmMode {
  SLIDER
  FORM
}

// A reminder/to-do item. One-off ("Una vez": dueDate set, recurrence null)
// or recurring (recurrence set, dueDate null). `recurrence` is a small JSON
// descriptor — e.g. {"type":"DAILY"} | {"type":"WEEKDAYS","days":[1,3,5]} |
// {"type":"MONTHLY","days":[1,15],"lastDay":true} — matched by a pure
// function in application code (`src/lib/recurrence.ts`), not queried at the
// DB level (personal-app data volume). `INTERVAL`/`YEARLY` recurrence types
// from the original design were dropped entirely in the 2026-07-23 redesign.
model Task {
  id           String       @id @default(cuid())
  title        String
  description  String?
  trackingType TrackingType @default(SIMPLE)
  // "Una vez" only: the event's date. `dueHasTime` says whether `dueDate`
  // also carries a meaningful time-of-day (event has a specific hour) or is
  // just a calendar day (time part is midnight, ignored).
  dueDate      DateTime?
  dueHasTime   Boolean      @default(false)
  recurrence   Json?
  // Free-text push body. Null/empty means "use the title verbatim" — no
  // auto-generated suffix (explicitly rejected by the owner).
  message      String?
  // COMPOUND only. Ignored for SIMPLE.
  confirmMode  ConfirmMode?
  // COMPOUND + FORM only: an array of FormFieldDef (see
  // src/lib/form-schema.ts) describing the fields to render on confirm.
  formSchema   Json?
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tags          Tag[]
  notifications TaskNotification[]
  completions   TaskCompletion[]
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  tasks Task[]
}

// One alert config per Task; a Task can have several. Which fields apply
// depends on the task's recurrence:
// - DAILY/WEEKDAYS (no date): `timeOfDay` (minutes since midnight) is the
//   only thing that matters — fires at that time on each due day.
// - Una vez/MONTHLY (has a date): `daysBefore` (0-90) + `timeOfDay` together
//   mean "N days before the occurrence, at HH:mm". For MONTHLY, this same
//   pair applies uniformly to every day-of-month configured on the task.
// `lastFiredForDate` is the dedupe guard so a sweep that runs every few
// minutes doesn't resend the same day's alert twice.
model TaskNotification {
  id                  String    @id @default(cuid())
  taskId              String
  task                Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  requireConfirmation Boolean   @default(false)
  timeOfDay           Int?
  daysBefore          Int?
  lastFiredForDate    DateTime? @db.Date
  createdAt           DateTime  @default(now())

  @@index([taskId])
}

// A logged completion of one occurrence of a Task. Only ever created for
// COMPOUND tasks (SIMPLE has no history to record). For confirmMode=SLIDER
// `data` is null (existence of the row is the done-marker); for
// confirmMode=FORM, `data` holds the submitted values keyed by field id from
// `Task.formSchema` — a GROUP field's value is an array of per-instance
// objects (see src/lib/form-schema.ts). One row per task per occurrence date.
model TaskCompletion {
  id          String   @id @default(cuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  forDate     DateTime @db.Date
  completedAt DateTime @default(now())
  data        Json?

  @@unique([taskId, forDate])
}
