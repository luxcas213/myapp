// Prisma schema — personal PWA (notes, tracker, push notifications)
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Accounts are created by the owner (script), not via public signup.
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String   @default("")
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Generic personal tracker entry. `kind` groups entries (e.g. "mood", "workout", "expense")
// and `data` holds kind-specific fields as JSON so new trackers don't need schema changes.
model TrackerEntry {
  id         String   @id @default(cuid())
  kind       String
  value      Float?
  note       String?
  data       Json?
  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([kind])
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}
